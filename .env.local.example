# Estas variables las genera Vercel automáticamente al crear la base
# desde la pestaña "Storage" y enlazarla al proyecto (vercel env pull).
# Aquí solo se muestran de referencia para desarrollo local.

POSTGRES_URL="postgres://usuario:contraseña@host:5432/verceldb?sslmode=require"
POSTGRES_PRISMA_URL="postgres://usuario:contraseña@host:5432/verceldb?pgbouncer=true&connect_timeout=15&sslmode=require"
POSTGRES_URL_NON_POOLING="postgres://usuario:contraseña@host:5432/verceldb?sslmode=require"
POSTGRES_USER="usuario"
POSTGRES_HOST="host"
POSTGRES_PASSWORD="contraseña"
POSTGRES_DATABASE="verceldb"

# Secreto propio para proteger el endpoint de limpieza automática (/api/cron/limpieza)
CRON_SECRET="genera-un-valor-aleatorio-largo"
